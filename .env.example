TG_TOKEN=your_bot_token_here
TG_CHAT=your_chat_id_here
TIMEZONE=Asia/Riyadh
PORT=3001
FIREBASE_PROJECT_ID=shada-task

# Service account JSON (required for Firestore)
# Get it from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the entire JSON content as one line:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"shada-task","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...","client_email":"..."}
